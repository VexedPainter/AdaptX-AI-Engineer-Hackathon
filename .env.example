# =============================================================================
# Constrained Structured Extraction at Scale — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values. Never commit .env to git.
# Follows 12-Factor App config principles: all secrets via environment.

# --- LLM Providers (4-Tier Fallback Chain) -----------------------------------
# Priority: Mistral (primary) → Cerebras → Groq → Gemini (final fallback)
# At minimum, configure ONE provider. All four are recommended for resilience.

# Primary: Mistral AI (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# 2nd Fallback: Cerebras (OpenAI-compatible endpoint, https://cloud.cerebras.ai/)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# 3rd Fallback: Groq (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# 4th Fallback: Google Gemini (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Guardrails (Optional) ---------------------------------------------------
# Enkrypt AI (enterprise). If not set, open-source fallback guardrails are used.
ENKRYPT_API_KEY=

# --- API Gateway Security ----------------------------------------------------
# JWT signing secret (generate: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_random_64_char_hex_string
# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Encryption ---------------------------------------------------------------
# AES-256 key for output store encryption (generate: openssl rand -hex 32)
AES_ENCRYPTION_KEY=change_me_to_a_random_64_char_hex_string

# --- LLM Configuration -------------------------------------------------------
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_MAX_RETRIES=3
LLM_RATE_LIMIT_RPM=30

# --- Qdrant -------------------------------------------------------------------
# In-memory mode by default (no server needed). Set URL for persistent mode.
QDRANT_URL=:memory:
QDRANT_COLLECTION_NAME=few_shot_examples

# --- Server -------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Demo Mode ----------------------------------------------------------------
# When true, POST /extract is publicly callable without JWT.
# Set to true for hackathon judging / live demo.
DEMO_MODE=true

# --- TLS (optional for local dev) ---------------------------------------------
TLS_CERT_PATH=
TLS_KEY_PATH=
