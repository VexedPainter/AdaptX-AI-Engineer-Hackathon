{
  "name": "constrained-structured-extraction",
  "version": "1.0.0",
  "description": "Constrained Structured Extraction at Scale — AI Engineer Hackathon",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.cpSync('src/public','dist/public',{recursive:true})\"",
    "dev": "tsx src/gateway/server.ts",
    "start": "node dist/gateway/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "evaluate": "tsx scripts/evaluate.ts",
    "evaluate:full": "tsx scripts/evaluate.ts --full",
    "seed": "tsx scripts/seed-qdrant.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@mastra/core": "^0.5.0",
    "@mistralai/mistralai": "^2.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^1.29.0",
    "@opentelemetry/sdk-metrics": "^1.29.0",
    "@opentelemetry/sdk-node": "^0.56.0",
    "@opentelemetry/sdk-trace-base": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "@xenova/transformers": "^2.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "groq-sdk": "^0.8.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.0",
    "openai": "^6.48.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
